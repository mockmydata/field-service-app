# Copy this to .env and fill in your values
# Expo exposes any var prefixed with EXPO_PUBLIC_ to the client bundle

# Base URL for your API (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=

# Optional: x-api-key for MockMyData / staging environments
# Leave blank or remove this line entirely for production and your own backend
#EXPO_PUBLIC_API_KEY=

#EXPO_PUBLIC_USE_MOCK_DATA=
